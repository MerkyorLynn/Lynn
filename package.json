{
  "name": "lynn",
  "version": "0.78.1",
  "type": "module",
  "description": "Lynn - a personal AI agent with memory and soul",
  "license": "Apache-2.0",
  "author": {
    "name": "liliMozi"
  },
  "keywords": [
    "ai-agent",
    "electron",
    "memory",
    "multi-platform",
    "telegram",
    "personal-assistant"
  ],
  "main": "desktop/main.cjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "npm run build:renderer && node scripts/launch.js electron",
    "start:dev": "node scripts/launch.js electron-dev",
    "start:vite": "node scripts/launch.js electron-vite",
    "dev:renderer": "vite --config vite.config.ts",
    "build:renderer": "vite build --config vite.config.ts",
    "typecheck": "tsc --noEmit",
    "cli": "node scripts/launch.js cli",
    "server": "node scripts/launch.js server",
    "build:main": "vite build --config vite.config.main.js",
    "pack": "export SKIP_NOTARIZE=true && npm run build:server && npm run build:main && npm run build:renderer && electron-builder --dir",
    "install:local": "npm run pack && rm -rf /Applications/Lynn.app && cp -R dist/mac-arm64/Lynn.app /Applications/ && node scripts/sign-local.cjs",
    "install:app": "rm -rf /Applications/Lynn.app && cp -R dist/mac-arm64/Lynn.app /Applications/ && codesign --verify --deep --strict /Applications/Lynn.app && echo \"Installed: /Applications/Lynn.app\"",
    "dist": "npm run release:preflight && electron-builder --mac dmg",
    "dist:local": "export SKIP_NOTARIZE=true && npm run build:server && npm run build:main && npm run build:renderer && electron-builder --mac dmg --publish never",
    "dist:win": "npm run release:preflight && npm run build:server:win && electron-builder --win nsis --x64",
    "test": "vitest run",
    "voice:smoke": "node scripts/voice-runtime-smoke.mjs",
    "test:release": "node scripts/run-release-regression.mjs --mode all --level release",
    "test:release:smoke": "node scripts/run-release-regression.mjs --mode all --level smoke",
    "test:release:nightly": "node scripts/run-release-regression.mjs --mode all --level nightly",
    "test:release:ui": "node scripts/run-electron-ui-smoke.mjs",
    "release:preflight": "npm test && npm run typecheck && npm run build:server && npm run build:main && npm run build:renderer && npm run test:release && npm run test:release:ui",
    "build:server": "node scripts/build-server.mjs",
    "build:server:win": "node scripts/build-server.mjs win32 x64",
    "release:manifest": "node scripts/generate-update-manifest.mjs",
    "release:finalize-mac": "APPLE_NOTARY_PROFILE=${APPLE_NOTARY_PROFILE:-hanako-notary} scripts/finalize-macos-dmg.sh dist/Lynn-${npm_package_version}-macOS-Apple-Silicon.dmg dist/Lynn-${npm_package_version}-macOS-Intel.dmg",
    "lint": "eslint desktop/src/ server/",
    "test:watch": "vitest",
    "postinstall": "node scripts/patch-pi-sdk.cjs"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/merge": "^6.12.1",
    "@hono/node-server": "^1.19.11",
    "@hono/node-ws": "^1.3.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@mariozechner/pi-agent-core": "^0.56.3",
    "@mariozechner/pi-ai": "^0.56.3",
    "@mariozechner/pi-coding-agent": "^0.56.3",
    "@mariozechner/pi-tui": "^0.56.3",
    "@sinclair/typebox": "^0.34.0",
    "@traptitech/markdown-it-katex": "^3.6.0",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "codemirror": "^6.0.2",
    "diff": "^9.0.0",
    "dompurify": "^3.3.3",
    "duck-duck-scrape": "^2.2.7",
    "edge-tts": "^1.0.1",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "hono": "^4.12.9",
    "js-yaml": "^4.1.0",
    "katex": "^0.16.39",
    "mammoth": "^1.11.0",
    "markdown-it": "^14.1.1",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.14.0",
    "node-telegram-bot-api": "^0.67.0",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.18.0",
    "zustand": "^5.0.11"
  },
  "overrides": {
    "form-data": "^4.0.0",
    "qs": "^6.14.1",
    "tough-cookie": "^4.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/diff": "^7.0.2",
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/nft": "^1.5.0",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^38.8.4",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^29.1.0",
    "msw": "^2.13.4",
    "patch-package": "^8.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.lynn.app",
    "productName": "Lynn",
    "asar": true,
    "asarUnpack": [
      "desktop/native-modules/aec/*.node"
    ],
    "compression": "maximum",
    "afterPack": "./scripts/fix-modules.cjs",
    "extraMetadata": {
      "main": "desktop/main.bundle.cjs"
    },
    "files": [
      "desktop/main.bundle.cjs",
      "desktop/preload.cjs",
      "desktop/native-modules/aec/index.js",
      "desktop/native-modules/aec/*.node",
      "desktop/dist-renderer/**",
      "desktop/src/**/*.html",
      "desktop/src/**/*.json",
      "desktop/src/**/*.svg",
      "desktop/src/icon.icns",
      "desktop/src/icon.png",
      "desktop/src/assets/tray-template*.png",
      "desktop/src/assets/tray-dev-template*.png",
      "desktop/src/assets/*.ico",
      "package.json",
      "!**/node_modules/**",
      "node_modules/ws/**"
    ],
    "extraResources": [
      {
        "from": "dist-server/${os}-${arch}/",
        "to": "server/"
      }
    ],
    "afterSign": "./scripts/notarize.cjs",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "icon": "desktop/src/icon.icns",
      "artifactName": "${productName}-${version}-macOS-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "timestamp": null,
      "sign": "./scripts/mac-sign-no-timestamp.cjs",
      "entitlements": "desktop/entitlements.mac.plist",
      "entitlementsInherit": "desktop/entitlements.mac.plist",
      "signIgnore": [
        "^.*\\.(png|jpg|jpeg|gif|webp|svg|ico|icns|woff|woff2|ttf|otf|html|css|json|md|txt|yaml|yml|wasm)$",
        "^.*\\.pak$",
        "^.*\\.bin$",
        "^.*\\.dat$",
        "^.*MainMenu\\.nib(/.*)?$"
      ]
    },
    "dmg": {
      "title": "Lynn",
      "contents": [
        {
          "x": 180,
          "y": 220
        },
        {
          "x": 420,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "MerkyorLynn",
        "repo": "Lynn"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "desktop/src/icon.png",
      "artifactName": "${productName}-${version}-Windows-Setup.${ext}",
      "requestedExecutionLevel": "asInvoker",
      "extraResources": [
        {
          "from": "vendor/git-portable",
          "to": "git"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    }
  },
  "msw": {
    "workerDirectory": [
      "desktop/src/public"
    ]
  }
}
