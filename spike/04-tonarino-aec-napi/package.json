{
  "name": "lynn-aec-napi",
  "version": "0.0.1",
  "description": "napi-rs binding for tonarino/webrtc-audio-processing — Lynn V0.79 AEC spike",
  "main": "lynn-aec-napi.node",
  "private": true,
  "scripts": {
    "build": "napi build --release --platform",
    "build:debug": "napi build --platform",
    "test": "node test/hello.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4"
  },
  "napi": {
    "name": "lynn-aec-napi",
    "triples": {
      "defaults": false,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "x86_64-pc-windows-msvc",
        "x86_64-unknown-linux-gnu"
      ]
    }
  }
}
